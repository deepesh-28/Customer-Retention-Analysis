      <aliases enabled='yes' />
      <column caption='Reference Date' datatype='datetime' name='[Calculation_0580328581275648]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEADD(&apos;day&apos;,1,{ FIXED :MAX([InvoiceDate]) })' />
      </column>
      <column caption='Sales Amount' datatype='real' name='[Calculation_0580328582287362]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[SaleQuantity]*[UnitPrice]' />
      </column>
      <column caption='Return Amount' datatype='real' name='[Calculation_0580328582447107]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[ReturnQuantity]*[UnitPrice]' />
      </column>
      <column caption='Order Month' datatype='datetime' name='[Calculation_0580328589131788]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [InvoiceDate])' />
      </column>
      <column caption='Cohort Month' datatype='datetime' name='[Calculation_0580328589279245]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [CustomerID] : MIN(DATETRUNC(&apos;month&apos;,[InvoiceDate])) }' />
      </column>
      <column caption='Cohort Index' datatype='integer' name='[Calculation_0580328589402126]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;month&apos;, [Calculation_0580328589279245], [Calculation_0580328589131788])' />
      </column>
      <column caption='No of Customers' datatype='integer' name='[Calculation_0580328589578255]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([CustomerID])' />
      </column>
      <column caption='Retention Rate' datatype='real' name='[Calculation_0580328589705232]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([CustomerID])&#13;&#10;/&#13;&#10;WINDOW_MAX(COUNTD([CustomerID]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_0580328612642836]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0580328582287362]) - SUM([Calculation_0580328582447107])' />
      </column>
      <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column caption='Customer ID' datatype='string' name='[CustomerID]' role='dimension' type='nominal' />
      <column aggregation='Sum' caption='F score' datatype='integer' name='[F_score]' role='dimension' type='ordinal' />
      <column caption='Invoice Date' datatype='date' name='[InvoiceDate]' role='dimension' type='ordinal' />
      <column caption='Invoice No' datatype='string' name='[InvoiceNo]' role='dimension' type='nominal' />
      <column caption='Is Return' datatype='boolean' name='[IsReturn]' role='dimension' type='nominal' />
      <column aggregation='Sum' caption='M score' datatype='integer' name='[M_score]' role='dimension' type='ordinal' />
      <column caption='No of Churned Customers' datatype='integer' name='[No of Customers (copy)_0580328622665767]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Recency]&gt;90 THEN [CustomerID] END)' />
      </column>
      <column aggregation='Sum' caption='R score' datatype='integer' name='[R_score]' role='dimension' type='ordinal' />
